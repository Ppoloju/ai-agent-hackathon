# Gemini API Key for Google ADK / Gemini API
GEMINI_API_KEY=your_gemini_api_key_here

# Google Calendar API configuration (OAuth 2.0)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Firebase Configuration
# Note: firebase-credentials.json should be placed in the project root directory
# This file is generated from Firebase Console > Project Settings > Service Accounts
# See README.md for detailed setup instructions
